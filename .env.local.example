# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Google Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key

# Optional: Firebase Admin SDK (for server-side operations)
FIREBASE_ADMIN_PRIVATE_KEY=your_private_key
FIREBASE_ADMIN_CLIENT_EMAIL=your_client_email

# Sentry — error monitoring (https://sentry.io)
# Required: public DSN (exposed to the browser is fine — it's not a secret)
NEXT_PUBLIC_SENTRY_DSN=
# Optional: environment label (e.g. production, preview, development)
NEXT_PUBLIC_SENTRY_ENV=development
# Optional: needed only for source-map uploads during next build
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
